# -----------------------------------------------------------------------------
# Front-end data source. Copy to `.env.local` and edit to switch backends.
# -----------------------------------------------------------------------------

# Which adapter the UI uses: "json" (default) or "mongo".
VITE_DATA_SOURCE=json

# JSON adapter: where the static data files live (served from /public).
VITE_JSON_BASE_PATH=/data

# Mongo adapter: base URL of the reference API in /server.
VITE_API_BASE_URL=http://localhost:4000/api

# Background music: path to the looping track (see public/audio/README.md).
VITE_MUSIC_SRC=/audio/theme.wav
